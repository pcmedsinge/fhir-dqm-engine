# -------------------------------------------------------
# Pramana — environment variables
# Copy to .env and fill in values. Never commit .env.
# -------------------------------------------------------

# Application
NODE_ENV=development         # development | test | production
PORT=3000                    # HTTP server port
LOG_LEVEL=info               # error | warn | info | debug | verbose

# CORS (comma-separated origins; leave empty to deny all cross-origin requests)
# CORS_ORIGINS=http://localhost:4200,http://localhost:5173

# FHIR server (Phase 2+)
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_REQUEST_TIMEOUT_MS=30000
FHIR_HEALTH_CHECK_TIMEOUT_MS=3000

# Measure engine (Phase 3+)
MEASURES_PATH=packages/engine/measures
MEASUREREPORT_PERSIST_TO_FHIR=true

# Value-set integrity (Phase 4+)
# When true (default in dev), Synthea-specific SNOMED codes in _synthetic-supplements/
# are merged into value sets at load time. Results are NOT VSAC-spec-compliant.
# Set to false in production to enforce canonical-only value sets.
ALLOW_SYNTHETIC_VALUESET_SUPPLEMENTS=true
