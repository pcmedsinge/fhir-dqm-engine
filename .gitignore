# =============================================================
# fhir-dqm-engine / Pramana — .gitignore
# Stack: Python (FastAPI) + .NET 8 + Java (cql-engine) + Node
# =============================================================


# -------------------------------------------------------------
# CRITICAL — healthcare data safety
# -------------------------------------------------------------
# Never commit real or test PHI. Only commit FHIR data that is
# either synthetic (e.g., Synthea-generated) AND clearly named,
# or shipped as small fixtures inside a `fixtures/` folder.

# Real / unverified clinical data — never commit
*.phi
*.phi.json
*.phi.ndjson
patient-data/
real-data/
phi/

# Synthea output (large; regenerate locally instead)
output/
synthea/
.synthea/
synthea-output/
*.synthea.json

# Large FHIR bundles and bulk-data exports
*.bundle.large.json
bulk-export/
ndjson-export/

# Allow: small named fixtures under fixtures/
# (these are explicitly safe to commit)
!fixtures/
!fixtures/**


# -------------------------------------------------------------
# Secrets, credentials, environment files
# -------------------------------------------------------------
.env
.env.*
!.env.example
*.env.local
secrets/
secrets.json
*.pem
*.key
*.pfx
*.p12
credentials.json
api-keys.txt
.aws/
.azure/


